{
  "name": "Chat Agent",
  "description": "Generic chat agent that proxies any LLM API. Supports OpenAI-compatible, Anthropic, Ollama and more — auto-detects format from URL.",
  "type": "template",
  "complexity": "beginner",
  "features": [
    "Any LLM provider support",
    "Auto-detect API format from URL",
    "System prompt configuration",
    "Temperature & max tokens control",
    "A2A protocol compatible",
    "Zero SDK — pure fetch()"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "LLM_API_URL",
    "LLM_API_KEY",
    "LLM_MODEL",
    "SYSTEM_PROMPT",
    "TEMPERATURE",
    "MAX_TOKENS"
  ],
  "icon": "💬",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}. {{AGENT_DESCRIPTION}}",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "methods": [
    {
      "name": "chat",
      "description": "Send a message and get a response",
      "params": {
        "messages": {
          "type": "array",
          "required": true,
          "description": "Array of {role, content} messages"
        },
        "context": {
          "type": "object",
          "required": false,
          "description": "Optional context"
        }
      },
      "returns": {
        "content": {
          "type": "string",
          "description": "Agent response"
        },
        "metadata": {
          "type": "object",
          "description": "{ model, tokens }"
        }
      },
      "example": {
        "request": {
          "jsonrpc": "2.0",
          "id": 1,
          "method": "chat",
          "params": {
            "messages": [
              {
                "role": "user",
                "content": "Hello"
              }
            ]
          }
        },
        "response": {
          "jsonrpc": "2.0",
          "id": 1,
          "result": {
            "content": "Hi! How can I help?",
            "metadata": {
              "model": "llama-3.3-70b"
            }
          }
        }
      }
    }
  ],
  "api": [
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/.well-known/agent-card.json",
      "description": "Agent discovery card"
    },
    {
      "method": "GET",
      "path": "/docs",
      "description": "API documentation (HTML)"
    },
    {
      "method": "POST",
      "path": "/api/chat",
      "description": "Direct chat endpoint"
    },
    {
      "method": "POST",
      "path": "/api/a2a/stream",
      "description": "A2A JSON-RPC 2.0 streaming endpoint"
    }
  ],
  "metadata": {
    "author": "agenxia",
    "source_template": null,
    "type": "template"
  }
}