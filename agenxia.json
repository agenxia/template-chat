{
  "name": "{{AGENT_NAME}}",
  "version": "1.0.0",
  "description": "{{AGENT_DESCRIPTION}}",
  "type": "agent",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}, a conversational AI assistant.",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "env_vars": ["LLM_API_URL", "LLM_API_KEY"],
  "ports": {
    "inputs": [
      { "id": "message", "label": "Message", "type": "text" },
      { "id": "context", "label": "Context", "type": "json" }
    ],
    "outputs": [
      { "id": "response", "label": "Response", "type": "text" }
    ]
  },
  "methods": [
    {
      "name": "process",
      "description": "Chat with context",
      "params": {
        "message": { "type": "string", "from_port": "message" },
        "context": { "type": "array", "from_port": "context" }
      },
      "returns": {
        "response": { "type": "string", "to_port": "response" }
      }
    }
  ],
  "api": {
    "chat": { "type": "stream", "description": "Conversational chat" },
    "status": { "type": "get", "description": "Agent status" }
  }
}